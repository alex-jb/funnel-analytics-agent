# Vercel — get token at vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=  # only if your project is under a team

# Product Hunt — register a developer app at api.producthunt.com/v2/oauth/applications
PH_DEV_TOKEN=
PH_LAUNCH_SLUG=vibexforge  # the slug from your producthunt.com/posts/<slug> URL

# Bypass — set to 1 to make the agent a no-op (e.g. on CI)
# FUNNEL_AGENT_SKIP=0
