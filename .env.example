# Vercel — get token at vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=  # only if your project is under a team

# Product Hunt — register a developer app at api.producthunt.com/v2/oauth/applications
PH_DEV_TOKEN=
PH_LAUNCH_SLUG=vibexforge  # the slug from your producthunt.com/posts/<slug> URL

# Supabase advisor — generate at supabase.com/dashboard/account/tokens (NOT the project anon/service key)
SUPABASE_PERSONAL_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=  # the slug in your dashboard URL, e.g. "yjqmquesxwlsmqowoahl"

# OpenPanel — generate the secret in dashboard → Project settings → Clients (separate from JS SDK ID)
OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=
# OPENPANEL_PROJECT_ID=             # optional if your client maps to one project
# OPENPANEL_TRACKED_EVENTS=signup_completed,project_submit_completed

# HyperDX — generate the QUERY key in HyperDX → Settings → Team → API Keys (NOT the ingestion key)
HYPERDX_API_KEY=
# HYPERDX_SERVICE=vibexforge-web   # matches NEXT_PUBLIC_SERVICE_NAME
# HYPERDX_LOOKBACK_HOURS=24

# Bypass — set to 1 to make the agent a no-op (e.g. on CI)
# FUNNEL_AGENT_SKIP=0

# Push notifiers — ANY ONE configured will receive briefs + alerts
# (1) ntfy.sh — free, no signup, just pick a topic name + subscribe via app
NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh    # override for self-hosted

# (2) Telegram — create bot at @BotFather, then message it once and grab
#     your chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# (3) Slack — Incoming Webhook URL from your Slack app settings
SLACK_WEBHOOK_URL=

# Default notifier list when --notify CLI flag is not given
# NOTIFIER_DEFAULT=ntfy
